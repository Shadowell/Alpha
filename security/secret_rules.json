{
  "rules": [
    {
      "id": "openai_api_key",
      "description": "Potential OpenAI API key in source code",
      "severity": "high",
      "pattern": "sk-[A-Za-z0-9_-]{20,}"
    },
    {
      "id": "feishu_app_secret",
      "description": "Potential Feishu app secret assignment",
      "severity": "high",
      "pattern": "(?i)FEISHU_APP_SECRET\\s*=\\s*[A-Za-z0-9_-]{16,}"
    },
    {
      "id": "discord_bot_token",
      "description": "Potential Discord bot token assignment",
      "severity": "high",
      "pattern": "(?i)DISCORD_BOT_TOKEN\\s*=\\s*[A-Za-z0-9._-]{20,}"
    },
    {
      "id": "hardcoded_password",
      "description": "Possible hardcoded password",
      "severity": "medium",
      "pattern": "(?i)(password|passwd|pwd)\\s*[:=]\\s*['\\\"][^'\\\"]{6,}['\\\"]"
    },
    {
      "id": "private_key_header",
      "description": "Private key marker in source",
      "severity": "high",
      "pattern": "-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----"
    }
  ]
}
